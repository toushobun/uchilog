# Supabase API 地址。必填。
# 本地获取：运行 `npx supabase status -o env`，使用 API_URL。
# 线上获取：Supabase 项目的 API 设置页面。
NEXT_PUBLIC_SUPABASE_URL=

# Supabase 浏览器端公开密钥。必填，可暴露给浏览器。
# 本地获取：运行 `npx supabase status -o env`，使用 PUBLISHABLE_KEY。
# 线上获取：Supabase 项目的 API keys 设置页面。
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase 服务端高权限密钥。与 SUPABASE_SECRET_KEY 二选一，不要暴露给浏览器。
# 如果两者同时配置，应用优先使用此变量。
# 仅在使用旧版 service_role JWT 时配置。
# 本地获取：运行 `npx supabase status -o env`，使用 SERVICE_ROLE_KEY。
# 线上获取：Supabase 项目的 API keys 设置页面。
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile 浏览器端 site key。注册页人机验证必填。
# 本地开发使用下方官方测试 site key；线上从 Cloudflare Turnstile 控制台获取。
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Supabase 服务端高权限密钥。与 SUPABASE_SERVICE_ROLE_KEY 二选一，不要暴露给浏览器。
# 新版 Supabase 项目优先使用此变量。
# 本地获取：运行 `npx supabase status -o env`，使用 SECRET_KEY。
# 线上获取：Supabase 项目的 API keys 设置页面。
SUPABASE_SECRET_KEY=

# Cloudflare Turnstile 服务端 secret key。注册页人机验证必填，不要暴露给浏览器。
# 本地开发使用下方官方测试 secret；线上从 Cloudflare Turnstile 控制台获取。
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
