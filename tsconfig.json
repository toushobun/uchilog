{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "accounts-molecules/*": ["./src/components/molecules/accounts/*"],
      "accounts/*": ["./src/components/organisms/accounts/*"],
      "accounts-page/*": ["./src/components/pages/accounts/*"],
      "accounts-template/*": ["./src/components/templates/accounts/*"],
      "auth/*": ["./src/components/organisms/auth/*"],
      "categories-page/*": ["./src/components/pages/categories/*"],
      "categories-template/*": ["./src/components/templates/categories/*"],
      "dashboard-molecules/*": ["./src/components/molecules/dashboard/*"],
      "dashboard-page/*": ["./src/components/pages/dashboard/*"],
      "dashboard-template/*": ["./src/components/templates/dashboard/*"],
      "home-page/*": ["./src/components/pages/home/*"],
      "home-template/*": ["./src/components/templates/home/*"],
      "ledger-setup-page/*": ["./src/components/pages/ledger-setup/*"],
      "ledger-setup-template/*": ["./src/components/templates/ledger-setup/*"],
      "ledgers-page/*": ["./src/components/pages/ledgers/*"],
      "ledgers-template/*": ["./src/components/templates/ledgers/*"],
      "login-page/*": ["./src/components/pages/login/*"],
      "login-template/*": ["./src/components/templates/login/*"],
      "merchants/*": ["./src/components/organisms/merchants/*"],
      "merchants-page/*": ["./src/components/pages/merchants/*"],
      "merchants-template/*": ["./src/components/templates/merchants/*"],
      "navigation-molecules/*": ["./src/components/molecules/navigation/*"],
      "providers/*": ["./src/components/providers/*"],
      "protected-template/*": ["./src/components/templates/protected/*"],
      "root-template/*": ["./src/components/templates/root/*"],
      "config/*": ["./src/config/*"],
      "settings-page/*": ["./src/components/pages/settings/*"],
      "settings-template/*": ["./src/components/templates/settings/*"],
      "server/*": ["./src/server/*"],
      "settings-components/*": ["./src/components/molecules/settings/*"],
      "statistics-page/*": ["./src/components/pages/statistics/*"],
      "statistics-template/*": ["./src/components/templates/statistics/*"],
      "theme/*": ["./src/theme/*"],
      "theme-components/*": ["./src/components/molecules/theme/*"],
      "types/*": ["./src/types/*"],
      "utils/*": ["./src/utils/*"],
      "ui/*": ["./src/components/atoms/ui/*"],
      "ui-molecules/*": ["./src/components/molecules/ui/*"],
      "lib/*": ["./src/lib/*"],
      "transactions/*": ["./src/components/organisms/transactions/*"],
      "transactions-atoms/*": ["./src/components/atoms/transactions/*"],
      "transactions-molecules/*": ["./src/components/molecules/transactions/*"],
      "transactions-page/*": ["./src/components/pages/transactions/*"],
      "transactions-template/*": ["./src/components/templates/transactions/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
