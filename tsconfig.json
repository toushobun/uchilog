{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "accounts/*": ["./src/components/organisms/accounts/*"],
      "auth/*": ["./src/components/organisms/auth/*"],
      "dashboard-page/*": ["./src/components/pages/dashboard/*"],
      "protected-template/*": ["./src/components/templates/protected/*"],
      "server/*": ["./src/server/*"],
      "settings-components/*": ["./src/components/molecules/settings/*"],
      "theme/*": ["./src/theme/*"],
      "theme-components/*": ["./src/components/molecules/theme/*"],
      "types/*": ["./src/types/*"],
      "utils/*": ["./src/utils/*"],
      "ui/*": ["./src/components/atoms/ui/*"],
      "ui-molecules/*": ["./src/components/molecules/ui/*"],
      "lib/*": ["./src/lib/*"],
      "transactions/*": ["./src/components/organisms/transactions/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
