# Environment sample for `supabase/config.restricted.example.toml`.
#
# Copy values from `npx supabase status` after starting Supabase.
# Keep this file as a reference only. Do not commit real `.env.local` secrets.

# Supabase API URL. This must point to the API/Kong port, not the PostgreSQL DB port.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55431
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key-from-supabase-status

# Server-side keys. Use values from `npx supabase status`.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key-from-supabase-status

# PostgreSQL connection string. This is the DB port.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/postgres
